{
  // 【必填】飞书机器人 Webhook 地址
  // 示例："https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN"
  // 安全设置：建议选择"关键词"，填写 "AnyRouter" 或 "签到" 等通知内容
  "webhook": "https://open.feishu.cn/open-apis/bot/v2/hook/c61793a3-031b-4dad-adcf-8bb42687f198",

  // 【可选】平台特定设置
  "platform_settings": {
    // 消息类型：card（卡片 json 1.0）| card_v2（卡片 json 2.0）| 其他（纯文本）
    "message_type": "card_v2",

    // 卡片颜色主题：`message_type` 为 `card` 或 `card_v2` 时生效
    // 支持静态颜色（blue/green/red/orange/purple/grey）或 stencil 动态模板
    // 留空则默认根据签到结果自动选择（全部成功=绿色，部分成功=橙色，全部失败=红色）
    "color_theme": "",
  },

  // 【可选】自定义通知模板（不设置，或为空时使用下方默认模板）
  "template": {
    // 通知标题，不设置，或为空字符串时不展示
    "title": "AnyRouter 签到提醒",

    // 通知内容
    "template": "{% if all_success %}**✅ 所有账号全部签到成功！**{% else %}{% if partial_success %}**⚠️ 部分账号签到成功**{% else %}**❌ 所有账号签到失败**{% endif %}{% endif %}\\n<br>\\n##### 详细信息\\n- **执行时间**：{{ timestamp }}\\n- **成功比例**：{{ stats.success_count }}/{{ stats.total_count }}\\n- **失败比例**：{{ stats.failed_count }}/{{ stats.total_count }}{% if has_success %}\\n\\n<br>\\n##### 成功账号\\n| 账号 | 已用（$） | 剩余（$） |\\n| :----- | :---- | :---- |\\n{% for account in success_accounts %}|{{ account.name }}|{{ account.used }}|{{ account.quota }}|\\n{% endfor %}{% endif %}{% if has_failed %}\\n<br>\\n##### 失败账号\\n| 账号 | 错误原因 |\\n| :----- | :----- |\\n{% for account in failed_accounts %}|{{ account.name }}|{{ account.error }}|\\n{% endfor %}{% endif %}",
  },
}
